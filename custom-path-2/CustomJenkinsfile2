pipeline { 
    agent any

    stages {
        stage('Checkout multiple sources') {
            steps {
                dir('source-1-test-1') {
                    git branch: 'main',
                        url: 'https://github.com/SignPath-Sandbox/Jenkins-test-1-scm-ps1.git'
                }

                dir('source-2-test-2') {
                    git branch: 'main',
                        url: 'https://github.com/SignPath-Sandbox/Jenkins-test-2-scm-ps1.git'
                }

                dir('source-3-test-3') {
                    git branch: 'main',
                        url: 'https://github.com/SignPath-Sandbox/Jenkins-test-3-scm-ps1.git'
                }

                sh '''
                    echo "=== Workspace ==="
                    ls -lh

                    echo "=== Source 1 ==="
                    ls -lh source-1-test-1 || true

                    echo "=== Source 2 ==="
                    ls -lh source-2-test-2 || true

                    echo "=== Source 3 ==="
                    ls -lh source-3-test-3 || true
                '''
            }
        }

        stage('Prepare artifact') {
            steps {
                sh '''
                    mkdir -p build-output

                    # Choose which checked-out repo provides the artifact to sign
                    cp source-3-test-3/script.ps1 build-output/script.ps1

                    echo "=== Artifact to sign ==="
                    ls -lh build-output
                    cat build-output/script.ps1
                '''
            }
        }

        stage('Archive artifact') {
            steps {
                archiveArtifacts artifacts: 'build-output/script.ps1', fingerprint: true
            }
        }

        stage('Sign with SignPath') {
            steps {
                submitSigningRequest(
                    apiTokenCredentialId: 'SignPath.ApiToken.QA1',
                    projectSlug: 'Jenkins-Project',
                    signingPolicySlug: 'Jenkins_signing_policy',
                    artifactConfigurationSlug: 'Powershell',
                    inputArtifactPath: 'build-output/script.ps1',
                    waitForCompletion: true
                )
            }
        }
    }
}
